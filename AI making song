<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Music Production Studio - Pro</title>
    <style>
        :root {
            --bg-color: #0b0f19;
            --panel-bg: #131a26;
            --accent-gold: #ffaa00;
            --accent-blue: #00e5ff;
            --text-color: #e2e8f0;
            --text-muted: #64748b;
            --border-color: #222f43;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            height: 100vh;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        header {
            background-color: var(--panel-bg);
            padding: 15px 25px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid var(--border-color);
        }

        header h1 {
            font-size: 1.4rem;
            color: var(--accent-blue);
            font-weight: 600;
            letter-spacing: 1px;
        }

        .studio-status {
            background: rgba(0, 229, 255, 0.1);
            color: var(--accent-blue);
            padding: 5px 12px;
            border-radius: 20px;
            font-size: 0.85rem;
            border: 1px solid rgba(0, 229, 255, 0.3);
        }

        .workspace {
            display: flex;
            flex: 1;
            overflow: hidden;
        }

        .panel {
            background-color: var(--panel-bg);
            border-right: 1px solid var(--border-color);
            display: flex;
            flex-direction: column;
            padding: 20px;
            overflow-y: auto;
        }

        .panel-left { flex: 1.2; min-width: 320px; }
        .panel-center { flex: 2; min-width: 450px; background-color: #0e1420; }
        .panel-right { flex: 1.2; min-width: 320px; border-right: none; }

        h2 {
            font-size: 1.05rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 15px;
            color: var(--accent-gold);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        textarea {
            width: 100%;
            height: 140px;
            background-color: var(--bg-color);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 12px;
            color: var(--text-color);
            resize: none;
            outline: none;
            font-size: 0.95rem;
        }

        .input-group { margin-bottom: 20px; }

        label {
            display: block;
            font-size: 0.85rem;
            color: var(--text-muted);
            margin-bottom: 8px;
        }

        .custom-select {
            background-color: var(--bg-color);
            border: 1px solid var(--border-color);
            color: var(--text-color);
            padding: 10px;
            border-radius: 6px;
            width: 100%;
            outline: none;
        }

        .upload-box {
            border: 2px dashed var(--border-color);
            background-color: rgba(255,255,255,0.02);
            border-radius: 10px;
            padding: 20px 15px;
            text-align: center;
            cursor: pointer;
        }

        /* Duration Audio Timeline Track */
        .timeline-box {
            background: #111823;
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 15px;
            margin-bottom: 20px;
        }

        .time-display {
            display: flex;
            justify-content: space-between;
            font-family: monospace;
            font-size: 0.9rem;
            color: var(--accent-blue);
            margin-bottom: 8px;
        }

        /* Mixer Track Styles */
        .mixer-track {
            background-color: var(--panel-bg);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 15px;
            margin-bottom: 12px;
            display: grid;
            grid-template-columns: 100px 1fr 60px 80px;
            align-items: center;
            gap: 15px;
        }

        .track-info .track-name { font-weight: 600; font-size: 0.95rem; }
        .track-info .track-key { font-size: 0.75rem; color: var(--accent-blue); margin-top: 2px; }

        .fader-container { display: flex; align-items: center; }
        
        .fader {
            -webkit-appearance: none;
            width: 100%;
            height: 6px;
            background: var(--bg-color);
            border-radius: 3px;
            outline: none;
        }

        .fader::-webkit-slider-thumb {
            -webkit-appearance: none;
            width: 16px;
            height: 16px;
            border-radius: 50%;
            background: var(--text-color);
            cursor: pointer;
            border: 2px solid var(--accent-blue);
        }

        /* Value Display Number */
        .value-display {
            font-family: monospace;
            font-size: 0.9rem;
            color: var(--accent-gold);
            text-align: right;
            background: #0b0f19;
            padding: 2px 6px;
            border-radius: 4px;
            border: 1px solid var(--border-color);
        }

        .track-controls { display: flex; gap: 5px; }

        .btn-mute, .btn-solo {
            background: var(--bg-color);
            border: 1px solid var(--border-color);
            color: var(--text-muted);
            padding: 4px 8px;
            font-size: 0.75rem;
            border-radius: 4px;
            cursor: pointer;
        }
        .btn-mute.active { background: #ef4444; color: white; }
        .btn-solo.active { background: #eab308; color: black; }

        /* Master Transpose */
        .master-box {
            background: linear-gradient(135deg, #1a2333 0%, #131a26 100%);
            border: 1px solid rgba(255, 170, 0, 0.3);
            border-radius: 10px;
            padding: 15px;
            margin-bottom: 20px;
        }

        .master-display {
            font-size: 2rem;
            font-weight: bold;
            text-align: center;
            color: var(--accent-gold);
            margin: 5px 0;
            font-family: monospace;
        }

        .video-preview {
            width: 100%;
            aspect-ratio: 16/9;
            background-color: #000;
            border-radius: 8px;
            position: relative;
            display: flex;
            justify-content: center;
            align-items: center;
            border: 1px solid var(--border-color);
            margin-bottom: 15px;
        }

        .video-lyrics {
            position: absolute;
            bottom: 15px;
            width: 90%;
            text-align: center;
            background: rgba(0,0,0,0.6);
            padding: 6px 12px;
            font-size: 0.9rem;
            border-left: 3px solid var(--accent-blue);
        }

        .btn-action {
            width: 100%;
            padding: 12px;
            border-radius: 6px;
            font-weight: 600;
            cursor: pointer;
            border: none;
            margin-bottom: 10px;
        }
        .btn-blue { background-color: var(--accent-blue); color: #000; }
        .btn-gold { background-color: var(--accent-gold); color: #000; }
    </style>
</head>
<body>

    <header>
        <h1>AI MUSIC PRODUCTION STUDIO</h1>
        <div class="studio-status">● AI Engine Ready</div>
    </header>

    <div class="workspace">
        
        <div class="panel panel-left">
            <h2>📝 1. Lyrics & Key Input</h2>
            <div class="input-group">
                <label>Song Lyrics (သီချင်းစာသား)</label>
                <textarea placeholder="စာသားများကို ဤနေရာတွင် ရိုက်ထည့်ပါ..."></textarea>
            </div>

            <div class="input-group">
                <label>Target Song Key</label>
                <select class="custom-select" id="keySelect">
                    <option value="C">C Major</option>
                    <option value="G" selected>G Major</option>
                    <option value="D">D Major</option>
                </select>
            </div>

            <h2>⏳ Song Duration (ကြာချိန်)</h2>
            <div class="timeline-box">
                <div class="time-display">
                    <span id="currentTime">01:15</span>
                    <span style="color: var(--text-muted);">/</span>
                    <span id="totalTime">03:45</span>
                </div>
                <input type="range" class="fader" min="0" max="225" value="75" oninput="updateTimeline(this.value)">
                <div style="display: flex; justify-content: space-between; font-size: 0.7rem; color: var(--text-muted); margin-top: 8px;">
                    <span>Verse 1 (0:00)</span>
                    <span>Chorus (1:02)</span>
                    <span>Bridge (2:30)</span>
                </div>
            </div>

            <h2>📁 3. AI Extraction</h2>
            <div class="upload-box" onclick="alert('AI Processing Started...')">
                <div style="font-size: 1.5rem; margin-bottom: 5px;">📥</div>
                <div style="font-size: 0.85rem; font-weight: 600;">Import Audio / Video</div>
            </div>
        </div>

        <div class="panel panel-center">
            <h2>🎛️ 2 & 6. Arrangements & Mixer Control</h2>
            <p style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 15px;">ဘားတံများနှင့် ဂဏန်းများဖြင့် အသေးစိတ် ညှိနှိုင်းမှုအပိုင်း</p>

            <div class="mixer-track">
                <div class="track-info">
                    <div class="track-name">🎤 Vocal</div>
                    <div class="track-key" id="vocalKeyStatus">Key: G Maj</div>
                </div>
                <div class="fader-container">
                    <input type="range" class="fader" min="0" max="100" value="85" oninput="updateVolDisplay('vocalVol', this.value)">
                </div>
                <div class="value-display" id="vocalVol">85%</div>
                <div class="track-controls">
                    <button class="btn-mute" onclick="this.classList.toggle('active')">M</button>
                    <button class="btn-solo" onclick="this.classList.toggle('active')">S</button>
                </div>
            </div>

            <div class="mixer-track">
                <div class="track-info">
                    <div class="track-name">🎹 Piano</div>
                    <div class="track-key" id="pianoKeyStatus">Key: G (Con)</div>
                </div>
                <div class="fader-container">
                    <input type="range" class="fader" min="0" max="100" value="70" oninput="updateVolDisplay('pianoVol', this.value)">
                </div>
                <div class="value-display" id="pianoVol">70%</div>
                <div class="track-controls">
                    <button class="btn-mute" onclick="this.classList.toggle('active')">M</button>
                    <button class="btn-solo" onclick="this.classList.toggle('active')">S</button>
                </div>
            </div>

            <div class="mixer-track">
                <div class="track-info">
                    <div class="track-name">🎸 Guitar</div>
                    <div class="track-key" id="guitarKeyStatus">Capo 2 (F)</div>
                </div>
                <div class="fader-container">
                    <input type="range" class="fader" min="0" max="100" value="75" oninput="updateVolDisplay('guitarVol', this.value)">
                </div>
                <div class="value-display" id="guitarVol">75%</div>
                <div class="track-controls">
                    <button class="btn-mute" onclick="this.classList.toggle('active')">M</button>
                    <button class="btn-solo" onclick="this.classList.toggle('active')">S</button>
                </div>
            </div>

            <div class="mixer-track">
                <div class="track-info">
                    <div class="track-name">🎷 Brass</div>
                    <div class="track-key" id="brassKeyStatus">Key: A</div>
                </div>
                <div class="fader-container">
                    <input type="range" class="fader" min="0" max="100" value="60" oninput="updateVolDisplay('brassVol', this.value)">
                </div>
                <div class="value-display" id="brassVol">60%</div>
                <div class="track-controls">
                    <button class="btn-mute" onclick="this.classList.toggle('active')">M</button>
                    <button class="btn-solo" onclick="this.classList.toggle('active')">S</button>
                </div>
            </div>
        </div>

        <div class="panel panel-right">
            <h2>🎚️ Master Transpose</h2>
            <div class="master-box">
                <div style="display:flex; justify-content:space-between; font-size:0.8rem; margin-bottom:10px;">
                    <span>🔗 Link Instruments</span>
                    <input type="checkbox" id="linkToggle" checked>
                </div>
                <div class="master-display" id="pitchValue">0 semitones</div>
                <input type="range" class="fader" id="pitchSlider" min="-6" max="6" value="0" step="1" oninput="updatePitch(this.value)">
            </div>

            <h2>🎬 5. Video Preview</h2>
            <div class="video-preview">
                <div style="color: #1e293b; font-size: 2rem;">🎬</div>
                <div class="video-lyrics" id="previewLyrics">စာတန်းထိုး Preview</div>
            </div>

            <div style="margin-top: auto;">
                <button class="btn-action btn-blue" onclick="alert('Merging Video & Audio...')">🎬 Generate Video</button>
                <button class="btn-action btn-gold" onclick="alert('Link Copied!')">📤 Share Studio Link</button>
            </div>
        </div>

    </div>

    <script>
        // အသံပမာဏ ဂဏန်းများကို Live ပြောင်းလဲပေးမည့် စနစ်
        function updateVolDisplay(elementId, value) {
            document.getElementById(elementId).innerText = value + "%";
        }

        // သီချင်းကြာချိန် ဘားတံ ဆွဲသည့်အခါ ဂဏန်းပြောင်းလဲပေးမည့် စနစ်
        function updateTimeline(seconds) {
            let min = Math.floor(seconds / 60);
            let sec = seconds % 60;
            let formattedTime = (min < 10 ? "0" : "") + min + ":" + (sec < 10 ? "0" : "") + sec;
            document.getElementById('currentTime').innerText = formattedTime;
        }

        // Pitch Master Slider အတွက် ဂဏန်းစနစ်
        function updatePitch(val) {
            let sign = val > 0 ? "+" : "";
            document.getElementById('pitchValue').innerText = sign + val + " semitones";

            let isLinked = document.getElementById('linkToggle').checked;
            if(isLinked) {
                if(val == 0) {
                    document.getElementById('vocalKeyStatus').innerText = "Key: G Maj";
                    document.getElementById('pianoKeyStatus').innerText = "Key: G (Con)";
                    document.getElementById('guitarKeyStatus').innerText = "Capo 2 (F)";
                    document.getElementById('brassKeyStatus').innerText = "Key: A";
                } else {
                    document.getElementById('vocalKeyStatus').innerText = "Shift: " + sign + val;
                    document.getElementById('pianoKeyStatus').innerText = "Aligned " + sign + val;
                    document.getElementById('guitarKeyStatus').innerText = "Capo Adapt";
                    document.getElementById('brassKeyStatus').innerText = "Transposed";
                }
            }
        }

        // စာရိုက်လျှင် ကာရာအိုကေစာတန်းထိုး လိုက်ပြောင်းခြင်း
        const textarea = document.querySelector('textarea');
        textarea.addEventListener('input', function() {
            document.getElementById('previewLyrics').innerText = this.value ? this.value.split('\n')[0] : "စာတန်းထိုး Preview";
        });
    </script>
</body>
</html>
